[global]
   workgroup = WORKGROUP
   server string = {{ inventory_hostname }} File Server
   security = user
   map to guest = Bad User
   log file = /var/log/samba/log.%m
   max log size = 50
   dns proxy = no
   server min protocol = SMB2

[public]
   comment = Partage public
   path = /srv/shared
   browseable = yes
   read only = no
   guest ok = yes
   guest only = yes
   create mask = 0664
   directory mask = 0775
